{
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/beta-digest",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/jobs-ingest",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/jobs-embed",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/jobs-score-fanout",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/jobs-score-drain",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/jobs-cleanup",
      "schedule": "0 4 * * *"
    }
  ]
}
